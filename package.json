{
  "name": "llmux-cli",
  "version": "0.2.12",
  "description": "LLM + mux (multiplexer), local AI API aggregation tool.",
  "type": "module",
  "main": "src/cli/index.ts",
  "bin": {
    "llmux": "bin/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "start": "bun run src/cli/index.ts start",
    "test": "bun test",
    "release": "bun run build.ts",
    "prepack": "cd ui && bun install && bun run build && cd .. && bun run pack-assets.ts && bun run release",
    "postinstall": "node scripts/install.js"
  },
  "keywords": [
    "llm",
    "ai",
    "gateway",
    "openai",
    "multiplexer"
  ],
  "author": "Moody",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhMoody/llmux-cli.git"
  },
  "bugs": {
    "url": "https://github.com/zhMoody/llmux-cli/issues"
  },
  "homepage": "https://github.com/zhMoody/llmux-cli#readme",
  "dependencies": {
    "@zh-moody/safe-env": "^0.4.3",
    "cac": "^6.7.14"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/bun": "latest"
  }
}
